0x0010 00000000000000000000000000000010 // 2 in data memory
0x1000 10000000000100000010000111001101 // sge R3, R1, R2
0x1004 10000000000000000110000011000000 // beq PR1, R3, R0 (if R1 < R2)
0x1008 10000000000000000110000101000001 // bne PR2, R3, R0 (else, so R1 >= R2)
0x100C 10000011111111111111111111111111 // halt for PR1
0x1010 10000010010100001000010010010000 // addi R09, R4, 10, PR1
0x1014 10000100001010001000010000010000 // addi R08, R4, 5, PR2
0x101C 10000101111111111111111111111111 // halt for PR2