        {
          "type": "script",
          "name": "Bake Rasterization State",
          "command": "python3 gen_graphics_test.py --mode triangle --res 50 50 --tri_idx 0 --angle 0.0 --out_init tri_init.hex --out_exp triangle_exp.hex"
        },
        {
          "type": "c_source",
          "name": "Run Triangle Shader",
          "compiler_flags": "-O2 -DGPU_SIM --entry kernel_triangle --rfc-size 4",
          "execution": {
            "threads": 2500,
            "blocks": 1,
            "arg_pointer": "0x20000100",
            "consumes": ["tri_init.hex"],
            "produces_mem": "triangle_out.hex"
          }
        }
      ],
      "verification": {
        "expected_file": "triangle_exp.hex",
        "float_tolerance": 0.015
      }
    },
