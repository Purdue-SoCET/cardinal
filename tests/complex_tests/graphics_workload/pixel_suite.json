{
  "suite_name": "Graphics Pipeline - Pixel Stage",
  "shared_config": {
    "c_source": {
      "compiler_flags": "-O2 -DGPU_SIM -Itests/complex_tests/graphics_workload/include/ --rfc-size 4",
      "source": "pixel.c"
    }
  },
  "tests": [
    {
      "name": "Pixel Shader - Full Cube Textured (50x50)",
      "pipeline": [
        {
          "type": "script",
          "name": "Bake Pipeline State & Textures",
          "command": "python3 gen_graphics_test.py --mode pixel --res 50 50 --angle 0.0 --out_init pixel_init.hex --out_exp pixel_exp.hex"
        },
        {
          "type": "c_source",
          "name": "Run Pixel Shader",
          "compiler_flags": "-O2 -DGPU_SIM --entry kernel_pixel --rfc-size 4",
          "execution": {
            "threads": 2500,
            "blocks": 1,
            "arg_pointer": "0x20010000",
            "consumes": ["pixel_init.hex"],
            "produces_mem": "pixel_out.hex"
          }
        },
        {
          "type": "script",
          "name": "Output Color Render",
          "command": "python3 render_hex.py --mode color --out color_render.png --res 50 50 pixel_out.hex"
        }
      ],
      "verification": {
        "expected_file": "pixel_exp.hex",
        "actual_file": "pixel_out.hex",
        "float_tolerance": 0.015
      }
    },
    {
      "name": "Pixel Shader - High Res Textured (100x100)",
      "pipeline": [
        {
          "type": "script",
          "name": "Bake Pipeline State & Textures",
          "command": "python3 gen_graphics_test.py --mode pixel --res 100 100 --angle 0.785398 --out_init pixel_init.hex --out_exp pixel_exp.hex"
        },
        {
          "type": "c_source",
          "name": "Run Pixel Shader",
          "compiler_flags": "-O2 -DGPU_SIM --entry kernel_pixel --rfc-size 4",
          "execution": {
            "threads": 10000,
            "blocks": 1,
            "arg_pointer": "0x20010000",
            "consumes": ["pixel_init.hex"],
            "produces_mem": "pixel_out.hex"
          }
        },
        {
          "type": "script",
          "name": "Output Color Render",
          "command": "python3 render_hex.py --mode color --out color_render.png --res 100 100 pixel_out.hex"
        }
      ],
      "verification": {
        "expected_file": "pixel_exp.hex",
        "actual_file": "pixel_out.hex",
        "float_tolerance": 0.015
      }
    }
  ]
}